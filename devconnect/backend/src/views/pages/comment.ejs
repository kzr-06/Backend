<%- include('../partials/navbar') %>

<h1><%= post.title %></h1>

<p><%= post.content %></p>

<hr>

<h3>Comments</h3>

<% if (comments && comments.length > 0) { %>
    <% comments.forEach(comment => { %>
        <p><%= comment.text %></p>
    <% }) %>
<% } else { %>
    <p>No comments yet</p>
<% } %>

