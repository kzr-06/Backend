<%- include('../partials/navbar') %>

<div class="container" style="max-width: 800px;">
    <% if (typeof post !== 'undefined' && post) { %>
        <article class="post-card">
            <h1><%= post.title %></h1>
            <div class="post-author" style="border-bottom: 1px solid var(--border); padding-bottom: 15px; margin-bottom: 25px;">
                <span style="color: var(--gold); font-weight: 700;">
                    <%= post.author && post.author.name ? post.author.name : 'Anonymous' %>
                </span>
                <span style="margin: 0 10px; color: var(--text-muted);">•</span>
                <span style="color: var(--text-muted);"><%= new Date(post.createdAt || Date.now()).toLocaleDateString() %></span>
            </div>
            
            <div style="font-size: 1.1rem; line-height: 1.8; white-space: pre-wrap; margin-bottom: 40px;"><%= post.content %></div>
            
            <% if (locals.user && post.author && (locals.user.userId === post.author.id || locals.user.userId === post.author._id.toString())) { %>
                <div class="card-actions">
                    <a href="/posts/<%= post._id %>/edit" class="btn-action">Edit Post</a>
                    <form action="/posts/<%= post._id %>/delete" method="POST" style="margin: 0; padding: 0; background: none; box-shadow: none; width: auto;">
                        <button type="submit" class="btn-action btn-delete" onclick="return confirm('Are you sure?')">Delete Post</button>
                    </form>
                </div>
            <% } %>
        </article>

        <!-- Comments Section -->
        <div class="comments-section" style="margin-top: 50px;">
            <h2>Comments (<%= comments ? comments.length : 0 %>)</h2>
            
            <% if (comments && comments.length > 0) { %>
                <div class="comments-list">
                    <% comments.forEach(comment => { %>
                        <div class="post-card" style="padding: 20px; margin-bottom: 20px; border-left: 4px solid var(--gold);">
                            <div style="font-size: 0.9rem; margin-bottom: 10px;">
                                <strong style="color: var(--gold);"><%= comment.author ? comment.author.name : 'Unknown' %></strong> 
                                <span style="color: var(--text-muted); margin-left: 10px;"><%= new Date(comment.createdAt).toLocaleDateString() %></span>
                            </div>
                            <div style="line-height: 1.6;"><%= comment.text %></div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p style="color: var(--text-muted); margin-bottom: 30px; font-style: italic;">No comments yet. Be the first to share your thoughts!</p>
            <% } %>

            <% if (locals.user) { %>
                <form action="/comments" method="POST" style="background: var(--card-bg); padding: 30px; box-shadow: none; width: 100%; border-radius: 15px;">
                    <input type="hidden" name="postId" value="<%= post._id %>" />
                    <label>Add a comment</label>
                    <textarea name="text" placeholder="Write your thoughts..." required rows="3"></textarea>
                    <button type="submit" class="btn-action" style="width: auto;">Post Comment</button>
                </form>
            <% } else { %>
                <div class="post-card" style="text-align: center; padding: 30px;">
                    <p style="color: var(--text-muted); margin-bottom: 20px;">You must be logged in to leave a comment.</p>
                    <a href="/auth/login" class="btn-action">Login to Comment</a>
                </div>
            <% } %>
        </div>
    <% } else { %>
        <div style="text-align: center; padding: 60px;">
            <h2 style="color: var(--text-muted);">Post not found.</h2>
            <a href="/dashboard" class="btn-action" style="margin-top: 30px;">Back to Dashboard</a>
        </div>
    <% } %>
</div>



<%- include('../partials/footer') %>
